GLOBAL {
        # The 2 byte prg header.
        INPUTOFFS 2;

        # The prg is actually loaded at $1000 and starts executing there, but that's just
        # a minimal bootstrapper that copies the rest of the file to -$1000 lower. So to
        # emulate that, we can just disassemble it as if it loaded to $0000. Same-same.
        STARTADDR $0000;
};

RANGE {
        TYPE SKIP;
        START $0000;
        END $01ff;
};

RANGE {
        TYPE SKIP;
        START $0213;
        END $0401;
};

RANGE {
        TYPE SKIP;
        START $05d5;
        END $05ff;
};

RANGE {
        TYPE SKIP;
        START $0800;
        END $ffff;
};

LABEL { ADDR $0696; NAME "start"; };
LABEL { ADDR $06c1; NAME "unpack"; };

LABEL { ADDR $0796; NAME "write_next"; SIZE 8; };
LABEL { ADDR $079f; NAME "read_next"; SIZE 8; };

LABEL { ADDR $00f0; NAME "write_pointer"; SIZE 2; };
LABEL { ADDR $00f2; NAME "read_pointer"; SIZE 2; };

LABEL { ADDR $00f4; NAME "prg_index"; };
LABEL { ADDR $0705; NAME "packed_prg_content_addresses_lo"; };
LABEL { ADDR $070d; NAME "packed_prg_content_addresses_hi"; };
RANGE { START $0705; END +16; TYPE BYTETABLE; };
